{
  "name": "lexvoice",
  "version": "1.1.7",
  "description": "Obsidian desktop plugin for recording, transcription, and AI-organized Markdown notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "transcription",
    "voice-notes",
    "meeting-notes"
  ],
  "author": "Lynnx",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.6.3"
  }
}
